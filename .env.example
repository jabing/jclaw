# JClaw 真实服务集成环境变量

# ========== LLM 配置 ==========
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ========== OpenViking 配置 ==========
# OpenViking 服务地址（Docker 内部使用）
OPENVIKING_URL=http://openviking:2033

# Embedding 模型配置
EMBEDDING_PROVIDER=openai
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=${OPENAI_API_KEY}
EMBEDDING_MODEL=text-embedding-3-large

# VLM 模型配置
VLM_PROVIDER=openai
VLM_API_BASE=https://api.openai.com/v1
VLM_API_KEY=${OPENAI_API_KEY}
VLM_MODEL=gpt-4-vision-preview

# ========== EvoMap 配置 ==========
EVOMAP_URL=https://evomap.ai/api
EVOMAP_API_KEY=your-evomap-api-key

# ========== 其他配置 ==========
NODE_ENV=production
LOG_LEVEL=info
